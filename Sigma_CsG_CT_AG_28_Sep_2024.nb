                "\[Transpose]"}], ".", 
               RowBox[{"vxk", "[", 
                RowBox[{"[", "i", "]"}], "]"}], ".", 
               RowBox[{"\[Psi]k", "[", 
                RowBox[{"[", 
                 RowBox[{"i", ",", "m"}], "]"}], "]"}]}], "]"}], "2"], ",", 
            RowBox[{"{", 
             RowBox[{"i", ",", "1", ",", 
              RowBox[{"vxk", "//", "Length"}]}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"n", ",", "1", ",", "Nb"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"m", ",", "1", ",", "Nb"}], "}"}]}], "]"}], ",", "2"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Do", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"\[Mu]", "=", 
           RowBox[{"\[Mu]kbT", "[", 
            RowBox[{"[", 
             RowBox[{"l", ",", "1"}], "]"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"kbT", "=", 
           RowBox[{"\[Mu]kbT", "[", 
            RowBox[{"[", 
             RowBox[{"l", ",", "2"}], "]"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"\[CapitalDelta]ETensor", "=", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"EkEkq", "-", "\[Mu]"}], ")"}], "/", "kbT"}]}], ";", 
          "\[IndentingNewLine]", "\[IndentingNewLine]", 
          RowBox[{"\[CapitalPi]k", "=", 
           RowBox[{
            RowBox[{
            "\[CapitalDelta]f\[CapitalDelta]\[Epsilon]", "[", 
             "\[CapitalDelta]ETensor", "]"}], "*", 
            RowBox[{"Fv", "/", "kbT"}]}]}], " ", ";", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"solchunks", "[", 
            RowBox[{"[", "l", "]"}], "]"}], "+=", 
           RowBox[{
            FractionBox[
             RowBox[{"2", 
              SuperscriptBox[
               RowBox[{"Norm", "[", "b1", "]"}], "2"]}], 
             RowBox[{"4", 
              SuperscriptBox["\[Pi]", "2"], 
              SuperscriptBox["nk", "2"]}]], 
            RowBox[{"Map", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"Total", "[", 
                FractionBox[
                 RowBox[{" ", "\[CapitalPi]k"}], 
                 RowBox[{"\[CapitalDelta]E", "+", 
                  RowBox[{"\[ImaginaryI]", " ", "\[Eta]"}], "+", "#"}]], 
                "]"}], "&"}], ",", "\[Omega]"}], "]"}]}]}], ";"}], 
         "\[IndentingNewLine]", ",", 
         RowBox[{"{", 
          RowBox[{"l", ",", "1", ",", 
           RowBox[{"\[Mu]kbT", "//", "Length"}]}], "}"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"ichunk", "==", "1"}], ",", " ", 
         RowBox[{"Print", "[", 
          RowBox[{"\"\<Estimated time: \>\"", ",", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"AbsoluteTime", "[", "]"}], "-", "time0"}], ")"}], "*", 
            
            RowBox[{"nch", "/", "60"}]}], ",", " ", "\"\< mins\>\""}], 
          "]"}]}], "]"}]}], "\[IndentingNewLine]", ",", 
      RowBox[{"{", 
       RowBox[{"ichunk", ",", "1", ",", "nch"}], "}"}]}], "]"}], ";", 
    "\[IndentingNewLine]", "solchunks"}], ")"}]}]}], "Input",
