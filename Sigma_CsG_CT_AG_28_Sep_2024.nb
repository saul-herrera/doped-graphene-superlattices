Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "IF", " ", "file", " ", "with", " ", "same", " ", "parameters", " ", 
     "exists"}], ",", " ", 
    RowBox[{"it", " ", "imports", " ", "it", " ", "instad", " ", "of", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"recalculating", "!!"}], "!!"}], "!"}]}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Temp", "=", "1"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Mu]0", "=", 
     RowBox[{"\[Mu]VHS", "-", "2.0"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Mu]f", "=", 
     RowBox[{"\[Mu]VHS", "+", "1.0"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Delta]\[Mu]", "=", "0.1"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"Print", "[", 
    RowBox[{
    "\"\<Parameters: {n, Temp, \[Eta], \[Omega]0, \[Omega]f, n\[Omega]} = \
\>\"", ",", 
     RowBox[{"{", 
      RowBox[{
      "n", ",", " ", "Temp", ",", " ", "\[Eta]", ",", "\[Omega]0", ",", 
       "\[Omega]f", ",", "n\[Omega]"}], "}"}]}], "]"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ParamString", "=", 
     RowBox[{
      RowBox[{"ToString", "[", "n", "]"}], "<>", "\"\<_\>\"", "<>", 
      RowBox[{"ToString", "[", "Temp", "]"}], "<>", "\"\<_\>\"", "<>", 
      RowBox[{"ToString", "[", "\[Eta]", "]"}], "<>", "\"\<_\>\"", "<>", 
      RowBox[{"ToString", "[", "\[Omega]0", "]"}], "<>", "\"\<_\>\"", "<>", 
      RowBox[{"ToString", "[", "\[Omega]f", "]"}], "<>", "\"\<_\>\"", "<>", 
      RowBox[{"ToString", "[", "n\[Omega]", "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"DataPath", "=", 
     RowBox[{"FileNameJoin", "[", 
      RowBox[{"{", 
       RowBox[{"FilePath", ",", "ParamString"}], "}"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"!", 
       RowBox[{"FileExistsQ", "[", "DataPath", "]"}]}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"CreateDirectory", "[", "DataPath", "]"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"FillingPath", "=", 
     RowBox[{"FileNameJoin", "[", 
      RowBox[{"{", 
       RowBox[{"DataPath", ",", 
        RowBox[{"\"\<filling_\>\"", "<>", 
         RowBox[{"ToString", "[", "\[Mu]0", "]"}], "<>", "\"\<_\>\"", "<>", 
         RowBox[{"ToString", "[", "\[Mu]f", "]"}], "<>", "\"\<_\>\"", "<>", 
         RowBox[{"ToString", "[", "\[Delta]\[Mu]", "]"}]}]}], "}"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"SigmaPath", "=", 
     RowBox[{"FileNameJoin", "[", 
      RowBox[{"{", 
       RowBox[{"FillingPath", ",", "\"\<\[Sigma].csv\>\""}], "}"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Mu]listkbT", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"i", ",", 
         RowBox[{"kBoltz", " ", "Temp"}]}], " ", "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "\[Mu]0", ",", "\[Mu]f", ",", "\[Delta]\[Mu]"}], 
        "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"FileExistsQ", "[", "SigmaPath", "]"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"\[Sigma]", "=", 
        RowBox[{"ToExpression", "@", 
         RowBox[{"Import", "[", "SigmaPath", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Print", "[", "\"\<Importing data. Done\>\"", "]"}], ";"}], 
      ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Print", "[", "\"\<No data found. Calculating...\>\"", "]"}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"\[CapitalPi]\[Omega]", "=", 
        RowBox[{"\[CapitalPi]loop", "[", "\[Mu]listkbT", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"\[Sigma]", "=", 
        RowBox[{"Map", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"\[Omega]", "\[Transpose]"}], ",", "#"}], "}"}], 
            "\[Transpose]"}], "&"}], ",", 
          RowBox[{"Im", "[", "\[CapitalPi]\[Omega]", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Export", "[", 
        RowBox[{"SigmaPath", ",", "\[Sigma]"}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Print", "[", "\"\<Completed.\>\"", "]"}], ";"}]}], 
     "\[IndentingNewLine]", "]"}], ";"}]}]}]], "Input",
