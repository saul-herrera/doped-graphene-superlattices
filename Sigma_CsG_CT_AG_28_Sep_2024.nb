Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Modify", " ", "only", " ", "n", " ", "and", " ", "n\[Omega]", " ", "for", 
    " ", 
    RowBox[{"more", "/", "less"}], " ", 
    RowBox[{"resolution", ".", " ", "Plots"}], " ", "in", " ", "paper", " ", 
    "produced", " ", "with", " ", "commented", " ", "values"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"n", " ", "=", " ", "400"}], 
    RowBox[{"(*", "400", "*)"}], ";"}], " ", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"n\[Omega]", "=", 
     RowBox[{"150", " ", "1"}]}], 
    RowBox[{"(*", "1500", "*)"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Mu]VHS", "=", 
     RowBox[{"\[Mu]VHSs", "[", 
      RowBox[{"[", "2", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"nk", "=", 
     RowBox[{"6", "n"}]}], ";"}], "  ", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Omega]f", "=", "5"}], ";"}], "\[IndentingNewLine]", " ", 
   RowBox[{
    RowBox[{"\[Omega]0", "=", "0."}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Eta]", "=", "0.01"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"FilePath", "=", 
     RowBox[{"FileNameJoin", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"NotebookDirectory", "[", "]"}], ",", "\"\<Data_Cs\>\""}], 
       "}"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"!", 
      RowBox[{"FileExistsQ", "[", "FilePath", "]"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"CreateDirectory", "[", "FilePath", "]"}]}], "]"}], 
   "\[IndentingNewLine]", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<nk= \>\"", ",", "nk"}], "]"}], "\[IndentingNewLine]", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Points in k mesh: \>\"", ",", 
     SuperscriptBox["nk", "2"]}], "]"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\[Mu]VHS = \>\"", ",", "\[Mu]VHS"}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[CapitalPi]loop", "[", "\[Mu]kbT_", "]"}], ":=", 
    RowBox[{"(", "\[IndentingNewLine]", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"\[CapitalDelta]\[Omega]", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"\[Omega]f", "-", "\[Omega]0"}], ")"}], "/", 
         "n\[Omega]"}]}], ";"}], "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{"\[Omega]", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"\[Omega]0", "+", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"i", "-", "1"}], ")"}], " ", 
            "\[CapitalDelta]\[Omega]"}]}], ",", 
