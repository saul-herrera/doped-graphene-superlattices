Cell[CellGroupData[{

Cell["Mesh Chunks", "Subsection",
 CellChangeTimes->{{3.896761995391655*^9, 
  3.8967620038922358`*^9}},ExpressionUUID->"742f375e-fad2-4fc6-9b6a-\
02940fcc3244"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Visualization", " ", "of", " ", "how", " ", "the", " ", "mesh", " ", "is",
     " ", "divided", " ", "into", " ", "chunks"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"hxg", "[", 
     RowBox[{"color_", ",", "vv_", ",", "kk_", ",", "kp_"}], "]"}], ":=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Thickness", "[", "vv", "]"}], ",", "color", ",", 
      RowBox[{"Line", "[", 
       RowBox[{"{", 
        RowBox[{"kk", ",", "kp", ",", 
         RowBox[{"kp", "-", "kk"}], ",", 
         RowBox[{"-", "kk"}], ",", 
         RowBox[{"-", "kp"}], ",", 
         RowBox[{"kk", "-", "kp"}], ",", "kk"}], "}"}], "]"}]}], "}"}]}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"nkTest", "=", 
     RowBox[{"6", " ", "2"}]}], ";", 
    RowBox[{"nchunksTest", "=", 
     RowBox[{"nkTest", "/", "3"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"kij", "=", 
     RowBox[{"Flatten", "[", 
      RowBox[{
       RowBox[{"IndicesCTchunk", "[", 
        RowBox[{"nkTest", ",", "1", ",", "1"}], "]"}], ",", "1"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"kb", "=", 
     RowBox[{"kij", ".", 
      RowBox[{"{", 
       RowBox[{"b1", ",", "b2"}], "}"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"Manipulate", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"PlotLat", "=", 
      RowBox[{"Graphics", "[", 
       RowBox[{
        RowBox[{"{", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"hxg", "[", 
           RowBox[{"Red", ",", "0.01", ",", "kk", ",", "kp"}], "]"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"Translate", "[", 
           RowBox[{
            RowBox[{"hxg", "[", 
             RowBox[{"Red", ",", "0.01", ",", "kk", ",", "kp"}], "]"}], ",", 
            "b1"}], "]"}], ",", "\[IndentingNewLine]", 
          RowBox[{"Translate", "[", 
           RowBox[{
            RowBox[{"hxg", "[", 
             RowBox[{"Red", ",", "0.01", ",", "kk", ",", "kp"}], "]"}], ",", 
            "b2"}], "]"}], ",", "\[IndentingNewLine]", 
          RowBox[{"Translate", "[", 
           RowBox[{
            RowBox[{"hxg", "[", 
             RowBox[{"Red", ",", "0.01", ",", "kk", ",", "kp"}], "]"}], ",", 
            RowBox[{"b1", "+", "b2"}]}], "]"}], ",", "\[IndentingNewLine]", 
          RowBox[{"Translate", "[", 
           RowBox[{
            RowBox[{"hxg", "[", 
             RowBox[{"Red", ",", "0.01", ",", "kk", ",", "kp"}], "]"}], ",", 
            RowBox[{"-", "b1"}]}], "]"}], ",", "\[IndentingNewLine]", 
          RowBox[{"Translate", "[", 
           RowBox[{
            RowBox[{"hxg", "[", 
             RowBox[{"Red", ",", "0.01", ",", "kk", ",", "kp"}], "]"}], ",", 
            RowBox[{"-", "b2"}]}], "]"}], ",", "\[IndentingNewLine]", 
          RowBox[{"Translate", "[", 
           RowBox[{
            RowBox[{"hxg", "[", 
             RowBox[{"Red", ",", "0.01", ",", "kk", ",", "kp"}], "]"}], ",", 
            RowBox[{
             RowBox[{"-", "b1"}], "-", "b2"}]}], "]"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"kijch", "=", 
            RowBox[{"Flatten", "[", 
             RowBox[{
              RowBox[{"IndicesCTchunk", "[", 
               RowBox[{"nkTest", ",", "nchunksTest", ",", "i"}], "]"}], ",", 
              "1"}], "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"kbch", "=", 
            RowBox[{"kijch", ".", 
             RowBox[{"{", 
              RowBox[{"b1", ",", "b2"}], "}"}]}]}], ";", 
