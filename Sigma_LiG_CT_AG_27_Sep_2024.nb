Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"hxg", "[", 
    RowBox[{"color_", ",", "vv_", ",", "kk_", ",", "kp_"}], "]"}], ":=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Thickness", "[", "vv", "]"}], ",", "color", ",", 
     RowBox[{"Line", "[", 
      RowBox[{"{", 
       RowBox[{"kk", ",", "kp", ",", 
        RowBox[{"kp", "-", "kk"}], ",", 
        RowBox[{"-", "kk"}], ",", 
        RowBox[{"-", "kp"}], ",", 
        RowBox[{"kk", "-", "kp"}], ",", "kk"}], "}"}], "]"}]}], "}"}]}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"nkTest", "=", 
   RowBox[{"6", " ", "2"}]}], ";", 
  RowBox[{"nchunksTest", "=", "1"}], ";", 
  RowBox[{"nqTest", "=", " ", "nkTest"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"kij", "=", 
   RowBox[{"Flatten", "[", 
    RowBox[{
