   RowBox[{"Memory", " ", "cuttofs", " ", "for", " ", "each", " ", "device"}],
    "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"LapMaxMemory", " ", "=", " ", "8"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"PCMaxMemory", " ", "=", " ", "80"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"MaxRAMallowed", " ", "=", "LapMaxMemory"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<nk= \>\"", ",", "nk"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<Points in k mesh: \>\"", ",", 
   SuperscriptBox["nk", "2"]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Print", "[", 
    RowBox[{"\"\<\[Mu]VHS = \>\"", ",", "\[Mu]VHS"}], "]"}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Omega]f", "=", "4"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{" ", 
  RowBox[{
   RowBox[{"\[Omega]0", "=", "0.0"}], ";"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"n\[Omega]", "=", "1500"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Eta]", "=", "0.01"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[CapitalPi]loop", "[", "\[Mu]kbT_", "]"}], ":=", 
  RowBox[{"(", "\[IndentingNewLine]", " ", 
   RowBox[{
    RowBox[{"\[CapitalDelta]\[Omega]", "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"\[Omega]f", "-", "\[Omega]0"}], ")"}], "/", "n\[Omega]"}]}], 
    ";", "\[IndentingNewLine]", " ", 
    RowBox[{"\[Omega]", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"\[Omega]0", "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"i", "-", "1"}], ")"}], " ", "\[CapitalDelta]\[Omega]"}]}], 
       ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "n\[Omega]"}], "}"}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"nch", "=", 
     RowBox[{"nk", "/", "3"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"solchunks", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{"0", ",", 
         RowBox[{"{", 
          RowBox[{"\[Omega]", "//", "Length"}], "}"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Mu]kbT", "//", "Length"}], "}"}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{
    "Print", "[", "\"\<Diagonalizing and building tensors...\>\"", "]"}], ";",
     "\[IndentingNewLine]", 
    RowBox[{"Do", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"time0", "=", 
        RowBox[{"AbsoluteTime", "[", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"kb", "=", 
        RowBox[{
         RowBox[{"Flatten", "[", 
          RowBox[{
           RowBox[{"IndicesCTchunk", "[", 
            RowBox[{"nk", ",", "nch", ",", "ichunk"}], "]"}], ",", "1"}], 
          "]"}], ".", 
         RowBox[{"{", 
          RowBox[{"b1", ",", "b2"}], "}"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Hkb", "=", 
        RowBox[{"Hk", "[", "kb", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"E\[Psi]k", "=", 
        RowBox[{"Map", "[", 
         RowBox[{"Eigensystem", ",", "Hkb"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"vxk", "=", 
        RowBox[{"vx", "[", "kb", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Ek", "=", 
        RowBox[{"E\[Psi]k", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";", " ", 
       RowBox[{"\[Psi]k", "=", 
        RowBox[{"E\[Psi]k", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"EkTensor", "=", 
        RowBox[{"Flatten", "[", 
         RowBox[{"KroneckerProduct", "[", 
          RowBox[{"Ek", ",", "e"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"EkqTensor", "=", 
        RowBox[{"Flatten", "[", 
         RowBox[{"KroneckerProduct", "[", 
          RowBox[{"e", ",", "Ek"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"\[CapitalDelta]E", "=", 
        RowBox[{"EkTensor", "-", "EkqTensor"}]}], ";", "\[IndentingNewLine]", 
       
       RowBox[{"EkEkq", "=", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"EkTensor", ",", 
           RowBox[{"EkqTensor", "\[Transpose]"}]}], "}"}], "\[Transpose]"}]}],
        ";", "\[IndentingNewLine]", 
       RowBox[{"Fv", "=", 
        RowBox[{"Flatten", "[", 
         RowBox[{
          RowBox[{"Table", "[", 
           RowBox[{
            SuperscriptBox[
             RowBox[{"Norm", "[", 
              RowBox[{
               RowBox[{
                RowBox[{
                 RowBox[{"\[Psi]k", "[", 
                  RowBox[{"[", 
                   RowBox[{"i", ",", "n"}], "]"}], "]"}], "\[Conjugate]"}], 
                "\[Transpose]"}], ".", 
               RowBox[{"vxk", "[", 
                RowBox[{"[", "i", "]"}], "]"}], ".", 
               RowBox[{"\[Psi]k", "[", 
                RowBox[{"[", 
                 RowBox[{"i", ",", "m"}], "]"}], "]"}]}], "]"}], "2"], ",", 
            RowBox[{"{", 
             RowBox[{"i", ",", "1", ",", 
              RowBox[{"vxk", "//", "Length"}]}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"n", ",", "1", ",", "Nb"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"m", ",", "1", ",", "Nb"}], "}"}]}], "]"}], ",", "2"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Do", "[", "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"\[Mu]", "=", 
           RowBox[{"\[Mu]kbT", "[", 
            RowBox[{"[", 
             RowBox[{"l", ",", "1"}], "]"}], "]"}]}], ";", 
