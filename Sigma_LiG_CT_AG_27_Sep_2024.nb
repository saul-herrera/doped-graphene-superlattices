Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Modify", " ", "only", " ", "n", " ", "and", " ", "n\[Omega]", " ", "for", 
    " ", 
    RowBox[{"more", "/", "less"}], " ", 
    RowBox[{"resolution", ".", " ", "Plots"}], " ", "in", " ", "paper", " ", 
    "produced", " ", "with", " ", "commented", " ", "values"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"n", " ", "=", " ", "40"}], 
    RowBox[{"(*", "400", "*)"}], ";"}], " ", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"n\[Omega]", "=", "150"}], 
    RowBox[{"(*", "1500", "*)"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Mu]VHS", "=", 
     RowBox[{"\[Mu]VHSs", "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"nk", "=", 
     RowBox[{"6", "n"}]}], ";"}], "  ", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Omega]f", "=", "4"}], ";"}], "\[IndentingNewLine]", " ", 
   RowBox[{
    RowBox[{"\[Omega]0", "=", "0.0"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Eta]", "=", "0.01"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"FilePath", "=", 
     RowBox[{"FileNameJoin", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"NotebookDirectory", "[", "]"}], ",", "\"\<Data_Li\>\""}], 
       "}"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"!", 
      RowBox[{"FileExistsQ", "[", "FilePath", "]"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"CreateDirectory", "[", "FilePath", "]"}]}], "]"}], 
   "\[IndentingNewLine]", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<nk= \>\"", ",", "nk"}], "]"}], "\[IndentingNewLine]", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Points in k mesh: \>\"", ",", 
     SuperscriptBox["nk", "2"]}], "]"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\[Mu]VHS = \>\"", ",", "\[Mu]VHS"}], "]"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[CapitalPi]loop", "[", "\[Mu]kbT_", "]"}], ":=", 
    RowBox[{"(", "\[IndentingNewLine]", " ", 
     RowBox[{
      RowBox[{"\[CapitalDelta]\[Omega]", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"\[Omega]f", "-", "\[Omega]0"}], ")"}], "/", "n\[Omega]"}]}],
       ";", "\[IndentingNewLine]", " ", 
      RowBox[{"\[Omega]", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"\[Omega]0", "+", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"i", "-", "1"}], ")"}], " ", 
           "\[CapitalDelta]\[Omega]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", "n\[Omega]"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"nch", "=", 
       RowBox[{"nk", "/", "3"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"solchunks", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{"0", ",", 
           RowBox[{"{", 
            RowBox[{"\[Omega]", "//", "Length"}], "}"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Mu]kbT", "//", "Length"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
      "Print", "[", "\"\<Diagonalizing and building tensors...\>\"", "]"}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"Do", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"time0", "=", 
          RowBox[{"AbsoluteTime", "[", "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"kb", "=", 
          RowBox[{
           RowBox[{"Flatten", "[", 
            RowBox[{
             RowBox[{"IndicesCTchunk", "[", 
              RowBox[{"nk", ",", "nch", ",", "ichunk"}], "]"}], ",", "1"}], 
            "]"}], ".", 
           RowBox[{"{", 
            RowBox[{"b1", ",", "b2"}], "}"}]}]}], ";", "\[IndentingNewLine]", 
         
         RowBox[{"Hkb", "=", 
          RowBox[{"Hk", "[", "kb", "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"E\[Psi]k", "=", 
          RowBox[{"Map", "[", 
           RowBox[{"Eigensystem", ",", "Hkb"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"vxk", "=", 
          RowBox[{"vx", "[", "kb", "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"Ek", "=", 
          RowBox[{"E\[Psi]k", "[", 
           RowBox[{"[", 
            RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";", " ", 
         RowBox[{"\[Psi]k", "=", 
          RowBox[{"E\[Psi]k", "[", 
           RowBox[{"[", 
            RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"EkTensor", "=", 
          RowBox[{"Flatten", "[", 
           RowBox[{"KroneckerProduct", "[", 
            RowBox[{"Ek", ",", "e"}], "]"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"EkqTensor", "=", 
          RowBox[{"Flatten", "[", 
           RowBox[{"KroneckerProduct", "[", 
            RowBox[{"e", ",", "Ek"}], "]"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"\[CapitalDelta]E", "=", 
          RowBox[{"EkTensor", "-", "EkqTensor"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"EkEkq", "=", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"EkTensor", ",", 
             RowBox[{"EkqTensor", "\[Transpose]"}]}], "}"}], 
           "\[Transpose]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"Fv", "=", 
          RowBox[{"Flatten", "[", 
           RowBox[{
            RowBox[{"Table", "[", 
             RowBox[{
              SuperscriptBox[
               RowBox[{"Norm", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{
                   RowBox[{"\[Psi]k", "[", 
                    RowBox[{"[", 
                    RowBox[{"i", ",", "n"}], "]"}], "]"}], "\[Conjugate]"}], 
                  "\[Transpose]"}], ".", 
                 RowBox[{"vxk", "[", 
                  RowBox[{"[", "i", "]"}], "]"}], ".", 
                 RowBox[{"\[Psi]k", "[", 
                  RowBox[{"[", 
                   RowBox[{"i", ",", "m"}], "]"}], "]"}]}], "]"}], "2"], ",", 
              
              RowBox[{"{", 
               RowBox[{"i", ",", "1", ",", 
                RowBox[{"vxk", "//", "Length"}]}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"n", ",", "1", ",", "Nb"}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"m", ",", "1", ",", "Nb"}], "}"}]}], "]"}], ",", "2"}],
            "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"Do", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{
            RowBox[{"\[Mu]", "=", 
             RowBox[{"\[Mu]kbT", "[", 
              RowBox[{"[", 
               RowBox[{"l", ",", "1"}], "]"}], "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"kbT", "=", 
             RowBox[{"\[Mu]kbT", "[", 
              RowBox[{"[", 
               RowBox[{"l", ",", "2"}], "]"}], "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"\[CapitalDelta]ETensor", "=", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"EkEkq", "-", "\[Mu]"}], ")"}], "/", "kbT"}]}], ";", 
            "\[IndentingNewLine]", "\[IndentingNewLine]", 
            RowBox[{"\[CapitalPi]k", "=", 
             RowBox[{
              RowBox[{
              "\[CapitalDelta]f\[CapitalDelta]\[Epsilon]", "[", 
               "\[CapitalDelta]ETensor", "]"}], "*", 
              RowBox[{"Fv", "/", "kbT"}]}]}], " ", ";", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"solchunks", "[", 
              RowBox[{"[", "l", "]"}], "]"}], "+=", 
             RowBox[{
              FractionBox[
               RowBox[{"2", 
                SuperscriptBox[
                 RowBox[{"Norm", "[", "b1", "]"}], "2"]}], 
               RowBox[{"4", 
                SuperscriptBox["\[Pi]", "2"], 
                SuperscriptBox["nk", "2"]}]], 
              RowBox[{"Map", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"Total", "[", 
                  FractionBox[
